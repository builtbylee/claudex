{
  "type": "object",
  "required": [
    "overall_status",
    "ready_to_approve",
    "summary",
    "unresolved",
    "regressions",
    "next_actions"
  ],
  "properties": {
    "overall_status": {
      "type": "string",
      "enum": [
        "resolved",
        "continue",
        "blocked",
        "insufficient_evidence"
      ]
    },
    "ready_to_approve": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    },
    "unresolved": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "reason",
          "missing_acceptance_criteria"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "must_fix",
              "should_fix",
              "advisory"
            ]
          },
          "category": {
            "type": "string",
            "enum": [
              "structural_mismatch",
              "missing_logic",
              "wrong_location",
              "behavioral_divergence"
            ]
          },
          "reason": {
            "type": "string"
          },
          "missing_acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "regressions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "title",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "must_fix",
              "should_fix",
              "advisory"
            ]
          },
          "category": {
            "type": "string",
            "enum": [
              "structural_mismatch",
              "missing_logic",
              "wrong_location",
              "behavioral_divergence"
            ]
          },
          "title": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
